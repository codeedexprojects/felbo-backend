# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/felbo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (User / Vendor)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY_SECONDS=2592000
JWT_REFRESH_EXPIRY=30d

# JWT (Admin)
JWT_ADMIN_EXPIRY_SECONDS=28800
JWT_ADMIN_REFRESH_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CHARGE_PERCENTAGE=2
RAZORPAY_TAX_PERCENTAGE=18

# Firebase (FCM push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# AWS S3 (file uploads + TTS)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# 2Factor (OTP)
TWO_FACTOR_API_KEY=
DEV_FIXED_OTP=123456
OTP_DAILY_LIMIT_USER=8
OTP_DAILY_LIMIT_VENDOR=10

# Brevo (transactional email)
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@felbo.in
BREVO_FROM_NAME=Felbo

# Booking
MAX_SERVICES_PER_BOOKING=3
